# ═══════════════════════════════════════════════
#  LLM Provider 配置
# ═══════════════════════════════════════════════

# Provider 类型：anthropic | openai | openai-compatible
LLM_PROVIDER=openai-compatible

# API Key（各 Provider 填对应的 Key）
LLM_API_KEY=sk-0b0bceed69528cc06d3a84d2e2c4d16a13e739249bb8aef6d5d0ca03206665b1

# 模型名称
# Anthropic 示例：claude-opus-4-6 / claude-sonnet-4-6 / claude-haiku-4-5-20251001
# OpenAI 示例：gpt-4o / gpt-4o-mini
# DeepSeek 示例：deepseek-chat / deepseek-reasoner
# Qwen 示例：qwen-max / qwen-turbo
LLM_MODEL=gpt-4o

# 自定义 Base URL（仅 openai-compatible 时填写）
# DeepSeek: https://api.deepseek.com/v1
# 阿里云 Qwen: https://dashscope.aliyuncs.com/compatible-mode/v1
# Azure OpenAI: https://<resource>.openai.azure.com/openai/deployments/<deploy>/
# Ollama 本地: http://localhost:11434/v1
LLM_BASE_URL=https://openai.xuya.dev/v1

# 最大重试次数（默认 3）
LLM_MAX_RETRIES=3

# ═══════════════════════════════════════════════
#  EMS Java 后端
# ═══════════════════════════════════════════════
EMS_BASE_URL=http://192.168.1.100:8080

# ═══════════════════════════════════════════════
#  邮件通知
# ═══════════════════════════════════════════════
SMTP_HOST=smtp.company.com
SMTP_PORT=465
SMTP_USER=ems-agent@company.com
SMTP_PASSWORD=

# ═══════════════════════════════════════════════
#  钉钉通知（群机器人 Webhook 方式）
#  在钉钉群 → 智能群助手 → 添加机器人 → 自定义机器人 → 复制 Webhook URL
# ═══════════════════════════════════════════════
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# ═══════════════════════════════════════════════
#  通知对象（逗号分隔）
# ═══════════════════════════════════════════════
OPERATOR_EMAILS=ops1@company.com,ops2@company.com
OPERATOR_DINGTALK_IDS=user_001,user_002

# ═══════════════════════════════════════════════
#  轮询配置
# ═══════════════════════════════════════════════
HEARTBEAT_INTERVAL_SECONDS=30
