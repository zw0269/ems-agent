# ═══════════════════════════════════════════════
#  LLM Provider 配置
# ═══════════════════════════════════════════════

# Provider 类型：anthropic | openai | openai-compatible
LLM_PROVIDER=anthropic

# API Key（各 Provider 填对应的 Key）
LLM_API_KEY=sk-ant-...

# 模型名称
# Anthropic 示例：claude-opus-4-6 / claude-sonnet-4-6 / claude-haiku-4-5-20251001
# OpenAI 示例：gpt-4o / gpt-4o-mini
# DeepSeek 示例：deepseek-chat / deepseek-reasoner
# Qwen 示例：qwen-max / qwen-turbo
LLM_MODEL=claude-opus-4-6

# 自定义 Base URL（仅 openai-compatible 时填写）
# openai.xuya.dev: https://openai.xuya.dev/v1
# DeepSeek: https://api.deepseek.com/v1
# 阿里云 Qwen: https://dashscope.aliyuncs.com/compatible-mode/v1
# Azure OpenAI: https://<resource>.openai.azure.com/openai/deployments/<deploy>/
# Ollama 本地: http://localhost:11434/v1
LLM_BASE_URL=

# OpenAI Responses API 兼容选项
# LLM_WIRE_API: chat（默认，/chat/completions）或 responses（/responses，支持 reasoning）
# 使用 openai.xuya.dev 等支持 Responses API 的代理时设为 responses
LLM_WIRE_API=chat
# Reasoning effort（仅 wire_api=responses 时生效）：low / medium / high / xhigh
LLM_REASONING_EFFORT=
# 禁止服务端存储对话（store: false）
LLM_DISABLE_RESPONSE_STORAGE=false

# 最大重试次数（默认 3）
LLM_MAX_RETRIES=3

# E5 可复现性：采样温度（默认 0.1，越低越稳定）
LLM_TEMPERATURE=0.1

# E2 Token 熔断：单条告警累计 input+output token 上限（默认 200000）
# 达到上限立即降级返回，防止复杂告警吞掉巨额费用
LLM_MAX_TOKENS_PER_ALARM=200000

# ═══════════════════════════════════════════════
#  E4 Shadow Mode（候选 prompt 对比）
# ═══════════════════════════════════════════════
# 打开后，每条告警会在 prod 推理的同时并行跑一轮候选 prompt
# 结果存 llm_calls.shadow_group='shadow'，不发通知
# 通过 /api/shadow/compare?alarmId=xxx 做 side-by-side
SHADOW_ENABLED=false
# 追加到 system prompt 末尾的候选补丁内容（例如新规则 R6）
SHADOW_PROMPT_APPEND=

# ═══════════════════════════════════════════════
#  R2 崩溃恢复
# ═══════════════════════════════════════════════
# 启动时将停留在 processing 状态超过此分钟数的告警强制置 error
RECOVERY_STALE_MINUTES=5

# ═══════════════════════════════════════════════
#  R4 聚类脚本（scripts/cluster-reflections.ts）
#  复用上方 LLM_PROVIDER / LLM_API_KEY / LLM_MODEL，不会额外调用其他大模型
# ═══════════════════════════════════════════════
# 回溯的 self_improvements 天数（默认 30）
CLUSTER_LOOKBACK_DAYS=30
# 单次聚类处理的反思建议条数上限（防超上下文，默认 100）
CLUSTER_MAX_ITEMS=100
# 最小聚类成员数（默认 2，孤立项丢弃）
CLUSTER_MIN_SIZE=2

# ═══════════════════════════════════════════════
#  EMS Java 后端
# ═══════════════════════════════════════════════
EMS_BASE_URL=http://192.168.1.100:8080

# ═══════════════════════════════════════════════
#  邮件通知 SMTP 配置
#
#  QQ 邮箱：
#    SMTP_HOST=smtp.qq.com  SMTP_PORT=465  SMTP_SECURE=true
#    SMTP_PASSWORD 填写「授权码」（QQ邮箱→设置→账户→开启SMTP服务→生成授权码）
#
#  163 邮箱：
#    SMTP_HOST=smtp.163.com  SMTP_PORT=465  SMTP_SECURE=true
#    SMTP_PASSWORD 填写「客户端授权密码」（163邮箱→设置→POP3/SMTP/IMAP）
#
#  企业邮箱 / 其他：
#    按邮件服务商提供的 SMTP 配置填写
# ═══════════════════════════════════════════════
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@qq.com
SMTP_PASSWORD=your_auth_code
SMTP_FROM_NAME=EMS Agent 告警

# ═══════════════════════════════════════════════
#  钉钉通知（群机器人 Webhook 方式）
#  在钉钉群 → 智能群助手 → 添加机器人 → 自定义机器人 → 复制 Webhook URL
# ═══════════════════════════════════════════════
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# ═══════════════════════════════════════════════
#  通知对象（逗号分隔）
# ═══════════════════════════════════════════════
OPERATOR_EMAILS=ops1@company.com,ops2@company.com
OPERATOR_DINGTALK_IDS=user_001,user_002

# ═══════════════════════════════════════════════
#  轮询配置
# ═══════════════════════════════════════════════
HEARTBEAT_INTERVAL_SECONDS=30

# ═══════════════════════════════════════════════
#  状态面板
# ═══════════════════════════════════════════════
# 访问地址：http://localhost:3000
STATUS_PORT=3000
